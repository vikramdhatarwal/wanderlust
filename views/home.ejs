<% layout('layouts/boilerplate') -%>
<section class="home-hero">
    <div class="home-hero-glow home-hero-glow-left"></div>
    <div class="home-hero-glow home-hero-glow-right"></div>

    <div class="row align-items-center g-4">
        <div class="col-12 col-lg-6">
            <p class="home-kicker">WanderLust</p>
            <h1 class="home-title">Find stays that feel like the Home, not just a stop.</h1>
            <p class="home-copy">
                Discover thoughtfully listed homes, cabins, and retreats built for weekend escapes,
                work trips, and long adventures.
            </p>
            <div class="home-actions">
                <a href="/listings" class="btn btn-outline-dark  home-primary-btn">Browse Listings</a>
                <a href="/listings/new" class="btn btn-outline-dark home-secondary-btn">Create Listing</a>
            </div>
            <div class="home-stats">
                <div class="home-stat-card">
                    <span class="home-stat-number">500+</span>
                    <span class="home-stat-label">Unique stays</span>
                </div>
                <div class="home-stat-card">
                    <span class="home-stat-number">24/7</span>
                    <span class="home-stat-label">Booking support</span>
                </div>
                <div class="home-stat-card">
                    <span class="home-stat-number">100%</span>
                    <span class="home-stat-label">Curated picks</span>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="home-feature-panel">
                <div class="home-feature-image-wrap">
                    <div class="home-feature-image"></div>
                </div>
                <div class="home-feature-content">
                    <p class="home-feature-label">Featured experience</p>
                    <h2>Comfort, character, and the right location.</h2>
                    <p>
                        Browse modern apartments, peaceful hill retreats, and bright city spaces with
                        clean layouts and trusted details.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>