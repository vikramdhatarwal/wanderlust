<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Listing</title>
</head>
<body>
    <h1>Edit Listing</h1>
    <form action="/listings/<%= listing._id %>?_method=PUT" method="POST">
        <div>
            <label for="title">Title:</label>
            <input type="text" id="title" name="listing[title]" value="<%= listing.title %>" required>
        </div>
        <div>
            <label for="description">Description:</label>
            <textarea id="description" name="listing[description]" required><%= listing.description %></textarea>
        </div>
        <div>
            <label for="imageUrl">Image URL:</label>
            <input type="text" id="imageUrl" name="listing[image][url]" value="<%= listing.image ? listing.image.url : '' %>">
        </div>
        <div>
            <label for="price">Price:</label>
            <input type="number" id="price" name="listing[price]" step="0.01" value="<%= listing.price %>" required>
        </div>
        <div>
            <label for="location">Location:</label>
            <input type="text" id="location" name="listing[location]" value="<%= listing.location %>" required>
        </div>
        <div>
            <label for="country">Country:</label>
            <input type="text" id="country" name="listing[country]" value="<%= listing.country %>" required>
        </div>
        <button type="submit">Update Listing</button>
</body>
</html>